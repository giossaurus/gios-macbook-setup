# Ghostty - configuração
# Fica em ~/.config/ghostty/config. Recarrega com Cmd+Shift+, (ou reabrindo o app).
# Docs: https://ghostty.org/docs/config

# --- Tema ---
# Temas custom (paleta do Cursor) ficam em themes/ ao lado deste arquivo.
# Alterna claro/escuro conforme a aparência do sistema:
theme = light:Cursor Light Real,dark:Cursor Dark Real

# --- Fonte ---
# Nerd Font pros ícones do prompt (powerlevel10k) e do eza.
font-family = "Symbols Nerd Font"
font-size = 14

# --- Janela ---
window-padding-x = 8
window-padding-y = 8
macos-titlebar-style = tabs
mouse-hide-while-typing = true
copy-on-select = clipboard

# --- Shell ---
# Deixe o zsh (login shell) cuidar do resto.
